--- !u!114 &1032978481
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1032978476}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 77dd0179abba37f4a90aea25626ec340, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC_Dialogue1
  npcMessage: "\u03A3\u03B5 \u03B1\u03C5\u03C4\u03CC \u03C4\u03BF \u03C4\u03B1\u03BE\u03AF\u03B4\u03B9,
    \u03BF \u03C3\u03C4\u03CC\u03C7\u03BF\u03C2 \u03C3\u03BF\u03C5 \u03B5\u03AF\u03BD\u03B1\u03B9
    \u03BD\u03B1 \u03BA\u03B1\u03C4\u03B1\u03BA\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2
    \u03C4\u03B7 \u03B3\u03BD\u03CE\u03C3\u03B7 \u03BA\u03B1\u03B9 \u03BD\u03B1 \u03B1\u03C0\u03BF\u03B4\u03B5\u03AF\u03BE\u03B5\u03B9\u03C2
    \u03CC\u03C4\u03B9 \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF\u03C2 \u03BD\u03B1 \u03BB\u03CD\u03C3\u03B5\u03B9\u03C2
    \u03BA\u03AC\u03B8\u03B5 \u03B3\u03C1\u03AF\u03C6\u03BF \u03BC\u03B1\u03B8\u03B1\u03AF\u03BD\u03C9\u03BD\u03C4\u03B1\u03C2
    \u03C4\u03B1 9 \u03B3\u03B5\u03B3\u03BF\u03BD\u03CC\u03C4\u03B1 \u03C4\u03BF\u03C5
    Gagne. \u0395\u03AF\u03C3\u03B1\u03B9 \u03AD\u03C4\u03BF\u03B9\u03BC\u03BF\u03C2
    \u03BD\u03B1 \u03B4\u03B5\u03B9\u03C2 \u03C4\u03B9 \u03C3\u03B5 \u03C0\u03B5\u03C1\u03B9\u03BC\u03AD\u03BD\u03B5\u03B9;"
  gagneExplanation: "\u0391\u03C5\u03C4\u03CC \u03C4\u03BF \u03B5\u03C6\u03AD \u03B1\u03BD\u03C4\u03B9\u03C0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B5\u03CD\u03B5\u03B9
    \u03C4\u03BF \u0394\u03B5\u03CD\u03C4\u03B5\u03C1\u03BF \u0393\u03B5\u03B3\u03BF\u03BD\u03CC\u03C2
    \u03C4\u03BF\u03C5 Gagne, \u03C0\u03BF\u03C5 \u03B5\u03BD\u03B7\u03BC\u03B5\u03C1\u03CE\u03BD\u03B5\u03B9
    \u03C4\u03BF\u03BD \u03BC\u03B1\u03B8\u03B7\u03C4\u03AE \u03B3\u03B9\u03B1 \u03C4\u03BF\u03C5\u03C2
    \u03C3\u03C4\u03CC\u03C7\u03BF\u03C5\u03C2 \u03C4\u03B7\u03C2 \u03BC\u03AC\u03B8\u03B7\u03C3\u03B7\u03C2!
    \u039A\u03BF\u03AF\u03C4\u03B1 \u03B4\u03B5\u03BE\u03B9\u03AC \u03C4\u03B7\u03BD
    \u03C0\u03CD\u03BB\u03B7 \u03C0\u03BF\u03C5 \u03B5\u03BC\u03C0\u03BF\u03B4\u03AF\u03B6\u03B5\u03B9
    \u03C4\u03B7 \u03B3\u03AD\u03C6\u03C5\u03C1\u03B1!"
  levelCompleteMessage: "\u03A5\u03C0\u03AD\u03C1\u03BF\u03C7\u03B1! \u039F \u03B4\u03C1\u03CC\u03BC\u03BF\u03C2
    \u03B3\u03B9\u03B1 \u03C4\u03BF \u0395\u03C0\u03AF\u03C0\u03B5\u03B4\u03BF 3
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B1\u03BD\u03BF\u03B9\u03C7\u03C4\u03CC\u03C2."
  dialoguePanel: {fileID: 1735318947}
  textDisplay: {fileID: 1317934181}
