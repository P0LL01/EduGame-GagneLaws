    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: npcMessage
      value: "\u03A3\u03B5 \u03B1\u03C5\u03C4\u03CC \u03C4\u03BF \u03C4\u03B1\u03BE\u03AF\u03B4\u03B9,
        \u03BF \u03C3\u03C4\u03CC\u03C7\u03BF\u03C2 \u03C3\u03BF\u03C5 \u03B5\u03AF\u03BD\u03B1\u03B9
        \u03BD\u03B1 \u03BA\u03B1\u03C4\u03B1\u03BA\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2
        \u03C4\u03B7 \u03B3\u03BD\u03CE\u03C3\u03B7 \u03BA\u03B1\u03B9 \u03BD\u03B1
        \u03B1\u03C0\u03BF\u03B4\u03B5\u03AF\u03BE\u03B5\u03B9\u03C2 \u03CC\u03C4\u03B9
        \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF\u03C2 \u03BD\u03B1 \u03BB\u03CD\u03C3\u03B5\u03B9\u03C2
        \u03BA\u03AC\u03B8\u03B5 \u03B3\u03C1\u03AF\u03C6\u03BF. \u0395\u03AF\u03C3\u03B1\u03B9
        \u03AD\u03C4\u03BF\u03B9\u03BC\u03BF\u03C2 \u03BD\u03B1 \u03B4\u03B5\u03B9\u03C2
        \u03C4\u03B9 \u03C3\u03B5 \u03C0\u03B5\u03C1\u03B9\u03BC\u03AD\u03BD\u03B5\u03B9;"
      objectReference: {fileID: 0}
