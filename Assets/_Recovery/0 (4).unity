      value: NPC4
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: npcMessage
      value: "\u039A\u03B1\u03BB\u03C9\u03C3\u03CC\u03C1\u03B9\u03C3\u03B5\u03C2
        \u03C3\u03C4\u03BF 4\u03BF \u03B5\u03C0\u03AF\u03C0\u03B5\u03B4\u03BF. \u0395\u03B4\u03CE
        \u03B2\u03C1\u03AF\u03C3\u03BA\u03B5\u03C4\u03B1\u03B9 \u03B7 \u03BA\u03B1\u03C1\u03B4\u03B9\u03AC
        \u03C4\u03B7\u03C2 \u03BC\u03AC\u03B8\u03B7\u03C3\u03B7\u03C2: \u03B7 \u03AF\u03B4\u03B9\u03B1
        \u03B7 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1! \u03A0\u03B1\u03C1\u03B1\u03C4\u03AE\u03C1\u03B7\u03C3\u03B5
        \u03C0\u03C1\u03BF\u03C3\u03B5\u03BA\u03C4\u03B9\u03BA\u03AC \u03B1\u03C5\u03C4\u03CC
        \u03C0\u03BF\u03C5 \u03B8\u03B1 \u03C3\u03BF\u03C5 \u03B1\u03C0\u03BF\u03BA\u03B1\u03BB\u03C5\u03C6\u03B8\u03B5\u03AF."
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: textDisplay
      value: 
      objectReference: {fileID: 550165593}
