      value: 
      objectReference: {fileID: 1097295266}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: gagneExplanation
      value: "\u0391\u03C5\u03C4\u03CC \u03C3\u03C5\u03BC\u03B2\u03BF\u03BB\u03AF\u03B6\u03B5\u03B9
        \u03C4\u03BF 4\u03BF \u0393\u03B5\u03B3\u03BF\u03BD\u03CC\u03C2 \u03C4\u03BF\u03C5
        Gagne (\u03A0\u03B1\u03C1\u03BF\u03C5\u03C3\u03AF\u03B1\u03C3\u03B7 \u03A5\u03BB\u03B9\u03BA\u03BF\u03CD).
        \u038C\u03C0\u03C9\u03C2 \u03B1\u03C5\u03C4\u03CC\u03C2 \u03BF \u03C0\u03C1\u03BF\u03B2\u03BF\u03BB\u03AD\u03B1\u03C2
        \"\u03C1\u03AF\u03C7\u03BD\u03B5\u03B9 \u03C6\u03C9\u03C2\" \u03C3\u03C4\u03BF
        \u03C3\u03BA\u03BF\u03C4\u03AC\u03B4\u03B9, \u03AD\u03C4\u03C3\u03B9 \u03BA\u03B1\u03B9
        \u03B7 \u03B5\u03BA\u03C0\u03B1\u03AF\u03B4\u03B5\u03C5\u03C3\u03B7 \u03B5\u03C3\u03C4\u03B9\u03AC\u03B6\u03B5\u03B9
        \u03C4\u03B7\u03BD \u03C0\u03C1\u03BF\u03C3\u03BF\u03C7\u03AE \u03C3\u03BF\u03C5
        \u03C3\u03C4\u03B7 \u03BD\u03AD\u03B1 \u03B3\u03BD\u03CE\u03C3\u03B7!"
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: levelCompleteMessage
      value: "\u0397 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1
