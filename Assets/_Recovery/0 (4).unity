    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: npcMessage
      value: "\u03A0\u03BF\u03BB\u03CD \u03C3\u03C9\u03C3\u03C4\u03AE \u03BA\u03AF\u03BD\u03B7\u03C3\u03B7!
        \u0397 \u03B5\u03C0\u03B9\u03BB\u03BF\u03B3\u03AE \u03C3\u03BF\u03C5 \u03BD\u03B1
        \u03C6\u03C4\u03AC\u03C3\u03B5\u03B9\u03C2 \u03BC\u03AD\u03C7\u03C1\u03B9
        \u03B5\u03B4\u03CE \u03AE\u03C4\u03B1\u03BD \u03B1\u03BA\u03C1\u03B9\u03B2\u03CE\u03C2
        \u03B1\u03C5\u03C4\u03AE \u03C0\u03BF\u03C5 \u03AD\u03C0\u03C1\u03B5\u03C0\u03B5.
        \u0395\u03AF\u03BD\u03B1\u03B9 \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03CC
        \u03BD\u03B1 \u03BE\u03AD\u03C1\u03B5\u03B9\u03C2 \u03C0\u03CC\u03C4\u03B5
        \u03B2\u03B1\u03B4\u03AF\u03B6\u03B5\u03B9\u03C2 \u03C3\u03C4\u03BF\u03BD
        \u03C3\u03C9\u03C3\u03C4\u03CC \u03B4\u03C1\u03CC\u03BC\u03BF."
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: textDisplay
      value: 
      objectReference: {fileID: 1864689780}
