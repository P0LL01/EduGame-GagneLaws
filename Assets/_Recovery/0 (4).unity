      value: 
      objectReference: {fileID: 1245563837}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: gagneExplanation
      value: "\u0391\u03C5\u03C4\u03CC \u03C3\u03C5\u03BC\u03B2\u03BF\u03BB\u03AF\u03B6\u03B5\u03B9
        \u03C4\u03BF 5\u03BF \u0393\u03B5\u03B3\u03BF\u03BD\u03CC\u03C2 \u03C4\u03BF\u03C5
        Gagne (\u039A\u03B1\u03B8\u03BF\u03B4\u03AE\u03B3\u03B7\u03C3\u03B7 \u03C4\u03B7\u03C2
        \u039C\u03AC\u03B8\u03B7\u03C3\u03B7\u03C2). \u038C\u03C0\u03C9\u03C2 \u03B1\u03C5\u03C4\u03CC
        \u03C4\u03BF \u03C6\u03C9\u03C4\u03B5\u03B9\u03BD\u03CC \u03BC\u03BF\u03BD\u03BF\u03C0\u03AC\u03C4\u03B9
        \u03C3\u03B5 \u03BA\u03B1\u03B8\u03BF\u03B4\u03B7\u03B3\u03B5\u03AF, \u03AD\u03C4\u03C3\u03B9
        \u03BA\u03B1\u03B9 \u03BF \u03B4\u03AC\u03C3\u03BA\u03B1\u03BB\u03BF\u03C2
        \u03B4\u03AF\u03BD\u03B5\u03B9 \u03C3\u03C4\u03BF\u03B9\u03C7\u03B5\u03AF\u03B1
        (hints) \u03B3\u03B9\u03B1 \u03BD\u03B1 \u03B2\u03BF\u03B7\u03B8\u03AE\u03C3\u03B5\u03B9
        \u03C4\u03BF\u03BD \u03BC\u03B1\u03B8\u03B7\u03C4\u03AE!"
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: levelCompleteMessage
      value: "\u0391\u03BA\u03BF\u03BB\u03BF\u03CD\u03B8\u03B7\u03C3\u03B5 \u03C4\u03B1
        \u03C3\u03B7\u03BC\u03AC\u03B4\u03B9\u03B1! \u03A4\u03BF \u03B5\u03BC\u03C0\u03CC\u03B4\u03B9\u03BF
        \u03AD\u03C0\u03B5\u03C3\u03B5, \u03BF \u03B4\u03C1\u03CC\u03BC\u03BF\u03C2
        \u03B3\u03B9\u03B1 \u03C4\u03BF \u0395\u03C0\u03AF\u03C0\u03B5\u03B4\u03BF
        6 \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B4\u03B9\u03BA\u03CC\u03C2 \u03C3\u03BF\u03C5."
      objectReference: {fileID: 0}
