    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: gagneExplanation
      value: "\u0391\u03C5\u03C4\u03CC \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C4\u03BF
        7\u03BF \u0393\u03B5\u03B3\u03BF\u03BD\u03CC\u03C2 \u03C4\u03BF\u03C5 Gagne
        (\u03A0\u03B1\u03C1\u03BF\u03C7\u03AE \u0391\u03BD\u03B1\u03C4\u03C1\u03BF\u03C6\u03BF\u03B4\u03CC\u03C4\u03B7\u03C3\u03B7\u03C2).
        \u038C\u03C0\u03C9\u03C2 \u03B2\u03BB\u03AD\u03C0\u03B5\u03B9\u03C2 \u03C4\u03BF
        \u03BC\u03AE\u03BD\u03C5\u03BC\u03B1 \u03B5\u03C0\u03B9\u03C4\u03C5\u03C7\u03AF\u03B1\u03C2
        \u03BD\u03B1 \u03B5\u03BC\u03C6\u03B1\u03BD\u03AF\u03B6\u03B5\u03C4\u03B1\u03B9
        \u03BC\u03C0\u03C1\u03BF\u03C3\u03C4\u03AC \u03C3\u03BF\u03C5, \u03AD\u03C4\u03C3\u03B9
        \u03BF \u03B4\u03AC\u03C3\u03BA\u03B1\u03BB\u03BF\u03C2 \u03B4\u03AF\u03BD\u03B5\u03B9
        \u03AC\u03BC\u03B5\u03C3\u03B7 \u03B5\u03C0\u03B9\u03B2\u03B5\u03B2\u03B1\u03AF\u03C9\u03C3\u03B7
        \u03C3\u03C4\u03BF\u03BD \u03BC\u03B1\u03B8\u03B7\u03C4\u03AE!"
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: levelCompleteMessage
      value: "\u03A3\u03C4\u03C1\u03AD\u03C8\u03B5 \u03C4\u03BF \u03B2\u03BB\u03AD\u03BC\u03B1
        \u03C3\u03BF\u03C5 \u03C8\u03B7\u03BB\u03AC \u03C0\u03AC\u03BD\u03C9 \u03B1\u03C0\u03C4\u03BF
        \u03BB\u03CC\u03C6\u03BF \u03BA\u03B1\u03B9 \u03B4\u03B5\u03C2! \u03A4\u03BF
        \u03B5\u03BC\u03C0\u03CC\u03B4\u03B9\u03BF \u03AD\u03C0\u03B5\u03C3\u03B5,
        \u03C4\u03BF \u0395\u03C0\u03AF\u03C0\u03B5\u03B4\u03BF 8 \u03C3\u03B5 \u03C0\u03B5\u03C1\u03B9\u03BC\u03AD\u03BD\u03B5\u03B9."
      objectReference: {fileID: 0}
