      value: NPC6
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: npcMessage
      value: "\u03A4\u03CE\u03C1\u03B1 \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B7 \u03C3\u03B5\u03B9\u03C1\u03AC
        \u03C3\u03BF\u03C5 \u03BD\u03B1 \u03B4\u03C1\u03AC\u03C3\u03B5\u03B9\u03C2!
        \u0397 \u03B8\u03B5\u03C9\u03C1\u03AF\u03B1 \u03B4\u03B5\u03BD \u03B1\u03C1\u03BA\u03B5\u03AF,
        \u03C0\u03C1\u03AD\u03C0\u03B5\u03B9 \u03BD\u03B1 \u03B4\u03BF\u03BA\u03B9\u03BC\u03AC\u03C3\u03B5\u03B9\u03C2
        \u03C4\u03B9\u03C2 \u03B4\u03C5\u03BD\u03AC\u03BC\u03B5\u03B9\u03C2 \u03C3\u03BF\u03C5
        \u03C3\u03C4\u03B7\u03BD \u03C0\u03C1\u03AC\u03BE\u03B7 \u03BA\u03B1\u03B9
        \u03BD\u03B1 \u03BB\u03CD\u03C3\u03B5\u03B9\u03C2 \u03C4\u03BF \u03C0\u03C1\u03CC\u03B2\u03BB\u03B7\u03BC\u03B1."
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: textDisplay
      value: 
      objectReference: {fileID: 157586285}
