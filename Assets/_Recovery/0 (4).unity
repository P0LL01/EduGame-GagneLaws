      value: 
      objectReference: {fileID: 278436029}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: spotlightEffect
      value: 
      objectReference: {fileID: 1747471666}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: gagneExplanation
      value: "\u0391\u03C5\u03C4\u03CC \u03B1\u03BD\u03C4\u03B9\u03C0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B5\u03CD\u03B5\u03B9
        \u03C4\u03BF 6\u03BF \u0393\u03B5\u03B3\u03BF\u03BD\u03CC\u03C2 \u03C4\u03BF\u03C5
        Gagne (\u0386\u03BD\u03C4\u03BB\u03B7\u03C3\u03B7 \u03C4\u03B7\u03C2 \u0391\u03C0\u03CC\u03B4\u03BF\u03C3\u03B7\u03C2).
        \u03A4\u03BF \u039A\u03CC\u03BA\u03BA\u03B9\u03BD\u03BF \u0394\u03B9\u03B1\u03BC\u03AC\u03BD\u03C4\u03B9
        \u03C3\u03C5\u03BC\u03B2\u03BF\u03BB\u03AF\u03B6\u03B5\u03B9 \u03C4\u03BF\u03BD
        \"\u03C3\u03C4\u03CC\u03C7\u03BF\" \u03BA\u03B1\u03B9 \u03C4\u03B7\u03BD
        \u03B5\u03BD\u03AD\u03C1\u03B3\u03B5\u03B9\u03B1 \u03C0\u03BF\u03C5 \u03B2\u03AC\u03B6\u03B5\u03B9\u03C2
        \u03B5\u03C3\u03CD \u03BF \u03AF\u03B4\u03B9\u03BF\u03C2 \u03B3\u03B9\u03B1
        \u03BD\u03B1 \u03B5\u03C6\u03B1\u03C1\u03BC\u03CC\u03C3\u03B5\u03B9\u03C2
        \u03CC\u03C3\u03B1 \u03AD\u03BC\u03B1\u03B8\u03B5\u03C2!"
      objectReference: {fileID: 0}
    - target: {fileID: 6769395508406656770, guid: 4dae7416af78b7e43b716534f08b2b9b, type: 3}
      propertyPath: levelCompleteMessage
      value: "\u0395\u03BE\u03B1\u03B9\u03C1\u03B5\u03C4\u03B9\u03BA\u03AE \u03C0\u03C1\u03BF\u03C3\u03C0\u03AC\u03B8\u03B5\u03B9\u03B1!
        \u0397 \u03B4\u03C1\u03AC\u03C3\u03B7 \u03C3\u03BF\u03C5 \u03B1\u03C0\u03AD\u03B4\u03C9\u03C3\u03B5
        \u03BA\u03B1\u03C1\u03C0\u03BF\u03CD\u03C2. \u039F \u03B4\u03C1\u03CC\u03BC\u03BF\u03C2
        \u03B3\u03B9\u03B1 \u03C4\u03BF \u0395\u03C0\u03AF\u03C0\u03B5\u03B4\u03BF
        7 \u03AC\u03BD\u03BF\u03B9\u03BE\u03B5."
